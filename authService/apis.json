            "description": "Returns true when the auth service is running."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                  "  if (json.token) pm.collectionVariables.set('refreshToken', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"user-001\",\n  \"username\": \"demo_user\",\n  \"password\": \"demo_password\",\n  \"firstname\": \"Demo\",\n  \"lastName\": \"User\",\n  \"phoneNo\": 9876543210,\n  \"email\": \"demo@example.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/v1/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "v1",
                "signup"
              ]
            },
            "description": "Creates a new user. Returns an accessToken on success."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                  "  if (json.token) pm.collectionVariables.set('refreshToken', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"demo_user\",\n  \"password\": \"demo_password\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/v1/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "v1",
                "login"
              ]
            },
            "description": "Authenticates a user. Returns accessToken and refresh token."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                  "  if (json.token) pm.collectionVariables.set('refreshToken', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{refreshToken}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/v1/refreshToken",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "v1",
                "refreshToken"
              ]
            },
            "description": "Uses a refresh token to issue a new accessToken."
          },
          "response": []
        },
        {
          "name": "Ping authenticated user",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/v1/ping",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "v1",
                "ping"
              ]
            },
            "description": "Requires a Bearer JWT. Returns the authenticated user's user id."
          },
          "response": []
        }
      ]
    }
  ]
